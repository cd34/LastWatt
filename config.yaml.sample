location:
  lat: 0.0000              # your latitude
  lon: 0.0000              # your longitude
  forecast_interval: 30m

state_file: /var/lib/lastwatt/state.json

# --- Flow meter ---
# TUF-2000M ultrasonic flow meter via Modbus RTU.
# Required for flow_override on action steps.
# flow_meter:
#   port: /dev/ttyUSB0
#   baud: 9600
#   slave_id: 1
#   interval: 5s

# --- Grid power loss ---
# monitor: pings a device on grid power to detect outages.
# start:   actions run when grid goes down.
# stop:    actions run when grid comes back.
# Mark individual actions with flow_override: true to allow them to be
# temporarily restored when water flow is detected.
grid:
  monitor:
    host: 192.168.1.X      # device on grid power — goes offline when grid is down
    interval: 5s
    fail_threshold: 3       # consecutive ping failures before curtailed
    recover_threshold: 2    # consecutive ping successes before normal
  start:
    - action: ecobee.read_mode
    - action: ecobee.set_hold
      params:
        heat_temp: 55
        cool_temp: 85
    - action: gpio.set
      params:
        pin: "17"
        state: off
        label: water_heater
      flow_override: true
    - action: gpio.set
      params:
        pin: "27"
        state: on
        label: curtail_led
    # - action: shelly.set
    #   params:
    #     host: 192.168.1.X
    #     state: off
    #     label: poe_switch
  stop:
    - action: ecobee.resume
    - action: gpio.set
      params:
        pin: "17"
        state: on
        label: water_heater
      flow_override: true
    - action: gpio.set
      params:
        pin: "27"
        state: off
        label: curtail_led
    # - action: shelly.set
    #   params:
    #     host: 192.168.1.X
    #     state: on
    #     label: poe_switch

# --- Time-of-use electricity rate windows ---
# Generates mid-peak and peak schedules automatically.
rates:
  timezone: America/Denver     # MST/MDT — automatic DST handling
  weekends_offpeak: true       # skip rate curtailment on Sat/Sun
  peak:
    start: "17:00"             # 5:00 PM
    end: "21:00"               # 9:00 PM
  mid_peak:
    start: "13:00"             # 1:00 PM
    end: "17:00"               # 5:00 PM
  start:
    - action: gpio.set
      params:
        pin: "17"
        state: off
        label: water_heater
      flow_override: true
  stop:
    - action: gpio.set
      params:
        pin: "17"
        state: on
        label: water_heater
      flow_override: true

# --- Vacation mode ---
# Polls the Ecobee thermostat for vacation events.
# Omit flow_override — nobody is home.  Add flow_override: true to
# individual steps if someone is still present (pet sitter, house guest).
vacation:
  poll_interval: 10m
  start:
    - action: gpio.set
      params:
        pin: "17"
        state: off
        label: water_heater
  stop:
    - action: gpio.set
      params:
        pin: "17"
        state: on
        label: water_heater

# --- Condition-based triggers ---
# Each trigger watches store values and runs start/stop actions on
# transitions.  Conditions are AND'd — all must be true to fire.
# Operators: ==, !=, >, <, >=, <=
# Available keys: tempest.temp_f, tempest.humidity, tempest.wind_mph,
#   tempest.solar_rad, ecobee.saved_mode, ecobee.vacation_active,
#   flow.flowing, flow.rate, schedule.active, trigger.<name>
# respect_holds: true (default) skips stop if grid/schedule/vacation hold active.
#                false runs stop regardless.
# triggers:
#   - name: heat_warning
#     when:
#       - "tempest.temp_f > 90"
#       - "ecobee.saved_mode == heat"
#     start:
#       - action: gpio.set
#         params: { pin: "22", state: on, label: heat_warning_led }
#     stop:
#       - action: gpio.set
#         params: { pin: "22", state: off, label: heat_warning_led }
#     respect_holds: false
#
#   - name: cold_warning
#     when:
#       - "tempest.temp_f < 32"
#       - "ecobee.saved_mode == cool"
#     start:
#       - action: gpio.set
#         params: { pin: "23", state: on, label: cold_warning_led }
#     stop:
#       - action: gpio.set
#         params: { pin: "23", state: off, label: cold_warning_led }
#     respect_holds: false
#
#   - name: window_open
#     when:
#       - "sensor.window == open"
#     start:
#       - action: ecobee.set_hold
#         params: { heat_temp: 60, cool_temp: 80 }
#     stop:
#       - action: ecobee.resume

# --- Custom schedules (optional) ---
# begin/end define the time window, start/stop define the actions.
# jitter adds a random offset of +/- the specified duration to the begin
# time, recomputed each day.
# schedules:
#   - name: evening_lights
#     days: [Mon, Tue, Wed, Thu, Fri]
#     begin: "22:00"
#     end: "06:00"
#     jitter: 10m
#     start:
#       - action: shelly.set
#         params: { host: 192.168.1.X, state: off, label: porch_light }
#     stop:
#       - action: shelly.set
#         params: { host: 192.168.1.X, state: on, label: porch_light }
